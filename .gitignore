# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/

# Generated files
*.freezed.dart
*.mocks.dart

# Hive database files (if you want to ignore local DB)
# Uncomment if you don't want to commit test data
# *.hive
# *.lock

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Web build
/web/flutter_service_worker.js
/web/flutter_service_worker.js.map
/web/version.json

# Firebase (if using)
# Uncomment if you want to ignore Firebase configs
# ios/Runner/GoogleService-Info.plist
# android/app/google-services.json

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/launch.json
.vscode/settings.json

# Ignore archive folder inside docs
docs/archive/
docs/archive/*
**/docs/archive/
**/docs/archive/*
